model ContactUs {
    id String @id @default(uuid())

    contactType ContactUsType
    inquiry     String
    fullName    String
    email       String
    message     String

    status ContactUsStatusEnum @default(PENDING)

    userId String?
    user   User?   @relation(fields: [userId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model NewsLetter {
    id String @id @default(uuid())

    email        String  @unique
    isSubscribed Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum ContactUsStatusEnum {
    PENDING
    IN_PROGRESS
    RESOLVED
    CLOSED
}

enum ContactUsType {
    QUESTION
    SUGGESTION
}
